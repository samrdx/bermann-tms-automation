# Bermann TMS QA Automation - Environment Variables Template
# Copy this file to .env and fill with your credentials

# TMS Environments
BASE_URL_DEV=https://moveontruckqa.bermanntms.cl
BASE_URL_STAGING=https://moveontruckqa.bermanntms.cl
BASE_URL_PROD=https://moveontruck.bermanntms.cl

# Configuration
ENVIRONMENT=dev
HEADLESS=false
TIMEOUT=30000

# Logging
LOG_LEVEL=info

# Test Users - REPLACE WITH YOUR CREDENTIALS
TEST_ADMIN_USER=your_admin_username_here
TEST_ADMIN_PASS=your_admin_password_here
TEST_REGULAR_USER=your_regular_username_here
TEST_REGULAR_PASS=your_regular_password_here

# CI/CD Alternative Names (GitHub Actions uses these)
# USERNAME_DEV=arivas
# PASSWORD_DEV=arivas

# DO NOT COMMIT .env TO GIT
# This template (.env.example) is safe to commit
# Your actual .env with real credentials should stay local