{
  "name": "qa-automation-framework",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf reports/* logs/*",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "// === SMOKE / AUTH ===": "",
    "test:auth": "playwright test tests/e2e/auth/",
    "test:auth:login": "playwright test tests/e2e/auth/login.test.ts",
    "test:auth:logout": "playwright test tests/e2e/auth/logout.test.ts",
    "// === ATOMIC (Estables) ===": "",
    "test:atomic:asignar": "playwright test tests/e2e/modules/02-operaciones/viajes/viajes-asignar.test.ts --headed",
    "test:atomic:finalizar": "playwright test tests/e2e/modules/02-operaciones/Monitoreo/viajes-finalizar.test.ts --project=chromium --headed",
    "test:atomic:all": "playwright test tests/e2e/modules/02-operaciones/viajes/viajes-asignar.test.ts tests/e2e/modules/02-operaciones/Monitoreo/viajes-finalizar.test.ts",
    "test:atomic:all:headed": "playwright test tests/e2e/modules/02-operaciones/viajes/viajes-asignar.test.ts tests/e2e/modules/02-operaciones/Monitoreo/viajes-finalizar.test.ts --headed",
    "// === LEGACY (A Auditar) ===": "",
    "test:legacy:setup": "playwright test tests/e2e/suites/base-entities.setup.ts",
    "test:legacy:setup:headed": "playwright test tests/e2e/suites/base-entities.setup.ts --headed",
    "test:legacy:entidades": "playwright test tests/e2e/modules/01-entidades/",
    "test:legacy:entidades:headed": "playwright test tests/e2e/modules/01-entidades/ --headed",
    "test:legacy:contratos": "playwright test tests/e2e/modules/02-operaciones/contratos/",
    "test:legacy:contratos:headed": "playwright test tests/e2e/modules/02-operaciones/contratos/ --headed",
    "test:legacy:planificar": "playwright test tests/e2e/modules/02-operaciones/viajes/viajes-planificar.test.ts",
    "test:legacy:planificar:headed": "playwright test tests/e2e/modules/02-operaciones/viajes/viajes-planificar.test.ts --headed",
    "// === GRANULAR (Debugging) ===": "",
    "test:entity:transportista": "playwright test tests/e2e/modules/01-entidades/transport/transportistas-crear.test.ts",
    "test:entity:cliente": "playwright test tests/e2e/modules/01-entidades/clientes/cliente-crear.test.ts",
    "test:entity:vehiculo": "playwright test tests/e2e/modules/01-entidades/vehiculos/vehiculo-crear.test.ts",
    "test:entity:conductor": "playwright test tests/e2e/modules/01-entidades/conductor/conductor-crear.test.ts",
    "test:op:contrato": "playwright test tests/e2e/modules/02-operaciones/contratos/contrato-crear.test.ts",
    "test:op:contrato2cliente": "playwright test tests/e2e/modules/02-operaciones/contratos/contrato2cliente-crear.test.ts",
    "// === FULL FLOWS ===": "",
    "test:full-flow": "playwright test tests/e2e/suites/base-entities.setup.ts tests/e2e/modules/02-operaciones/contratos/ tests/e2e/modules/02-operaciones/viajes/ tests/e2e/modules/02-operaciones/Monitoreo/ --workers=1 --project=chromium --reporter=html",
    "test:all": "playwright test tests/e2e/modules/",
    "// === UTILITIES ===": "",
    "show-report": "playwright show-report",
    "codegen": "playwright codegen https://moveontruckqa.bermanntms.cl"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "playwright": "^1.58.0",
    "playwright-core": "^1.58.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.19.30",
    "cross-env": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
