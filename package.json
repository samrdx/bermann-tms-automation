{
  "name": "qa-automation-framework",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf reports/* logs/*",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "// === BASE SUITE ===": "",
    "test:base": "playwright test tests/e2e/suites/base-entities.setup.ts",
    "test:base:headed": "playwright test tests/e2e/suites/base-entities.setup.ts --headed",
    "// === ENTITY TESTS (01-entidades) ===": "",
    "test:transportista": "playwright test tests/e2e/modules/01-entidades/transport/transportistas-crear.test.ts",
    "test:cliente": "playwright test tests/e2e/modules/01-entidades/clientes/cliente-crear.test.ts",
    "test:vehiculo": "playwright test tests/e2e/modules/01-entidades/vehiculos/vehiculo-crear.test.ts",
    "test:conductor": "playwright test tests/e2e/modules/01-entidades/conductor/conductor-crear.test.ts",
    "// === OPERATION TESTS (02-operaciones) ===": "",
    "test:contrato": "playwright test tests/e2e/modules/02-operaciones/contratos/contrato-crear.test.ts",
    "test:contrato:debug": "playwright test tests/e2e/modules/02-operaciones/contratos/contrato-crear.test.ts --project=chromium --headed",
    "test:contrato2cliente": "playwright test tests/e2e/modules/02-operaciones/contratos/contrato2cliente-crear.test.ts",
    "test:viajes:planificar": "playwright test tests/e2e/modules/02-operaciones/viajes/viajes-planificar.test.ts",
    "test:viajes:asignar": "playwright test tests/e2e/modules/02-operaciones/viajes/viajes-asignar.test.ts",
    "// === FULL FLOWS ===": "",
    "test:all": "playwright test tests/e2e/modules/",
    "// === UTILITIES ===": "",
    "show-report": "playwright show-report",
    "codegen": "playwright codegen https://moveontruckqa.bermanntms.cl"
  },
  "dependencies": {
    "@browserbasehq/stagehand": "^3.0.8",
    "@playwright/test": "^1.58.0",
    "dotenv": "^16.6.1",
    "playwright": "^1.58.0",
    "playwright-core": "^1.58.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.30",
    "cross-env": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}