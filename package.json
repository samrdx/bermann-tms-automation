{
  "name": "qa-automation-framework",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "test": "tsx tests/example.test.ts",
    "test:headed": "cross-env HEADLESS=false tsx tests/example.test.ts",
    "test:explore": "cross-env HEADLESS=false tsx tests/explore-login.ts",
    "test:experiments": "cross-env HEADLESS=false tsx tests/login-experiments.ts",
    "test:login": "cross-env HEADLESS=false tsx tests/login.test.ts",
    "test:login:headless": "cross-env HEADLESS=true tsx tests/login.test.ts",
    "test:explore:dashboard": "cross-env HEADLESS=false tsx tests/explore-dashboard.ts",
    "test:logout": "cross-env HEADLESS=false tsx tests/logout.test.ts",
    "test:dashboard": "cross-env HEADLESS=false tsx tests/dashboard.test.ts",
    "test:full-flow": "cross-env HEADLESS=false tsx tests/full-flow.test.ts",
    "test:login:negative": "cross-env HEADLESS=false tsx tests/login-negative.test.ts",
    "test:all": "npm run test:login && npm run test:logout && npm run test:full-flow && npm run test:login:negative",
    "test:stagehand": "cross-env HEADLESS=false tsx tests/stagehand-login.test.ts",
    "test:stagehand:simple": "cross-env HEADLESS=false tsx tests/stagehand-simple.test.ts",
    "test:stagehand:ai-login": "cross-env HEADLESS=false tsx tests/stagehand-login-ai.test.ts",
    "build": "tsc",
    "clean": "rm -rf dist logs/*.log reports/screenshots/*.png"
  },
  "dependencies": {
    "@browserbasehq/stagehand": "^3.0.8",
    "@playwright/test": "^1.58.0",
    "dotenv": "^16.6.1",
    "playwright": "^1.58.0",
    "playwright-core": "^1.58.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.30",
    "cross-env": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
