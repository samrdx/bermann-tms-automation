{
  "name": "qa-automation-framework",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf reports/* logs/*",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "// === SMOKE / AUTH ===": "",
    "test:auth": "playwright test tests/e2e/auth/ ",
    "test:auth:login": "playwright test tests/e2e/auth/login.test.ts",
    "test:auth:logout": "playwright test tests/e2e/auth/logout.test.ts",
    "// === SMOKE TMS ENV=QA (Default) ===": "",
    "test:entity:transportista": "playwright test tests/e2e/modules/01-entidades/transport/transportistas-crear.test.ts --trace on",
    "test:entity:cliente": "playwright test tests/e2e/modules/01-entidades/clientes/cliente-crear.test.ts --trace on",
    "test:entity:vehiculo": "playwright test tests/e2e/modules/01-entidades/vehiculos/vehiculo-crear.test.ts --trace on",
    "test:entity:conductor": "playwright test tests/e2e/modules/01-entidades/conductor/conductor-crear.test.ts --trace on",
    "test:op:contrato": "playwright test tests/e2e/modules/02-operaciones/contratos/contrato-crear.test.ts --trace on",
    "test:op:contrato2cliente": "playwright test tests/e2e/modules/02-operaciones/contratos/contrato2cliente-crear.test.ts --trace on",
    "test:trip:planificar": "npx playwright test tests/e2e/modules/02-operaciones/viajes/viajes-planificar.test.ts --trace on",
    "test:trip:asignar": "playwright test tests/e2e/modules/02-operaciones/viajes/viajes-asignar.test.ts --trace on",
    "test:trip:finalizar": "npx playwright test tests/e2e/modules/02-operaciones/Monitoreo/viajes-monitoreo.test.ts --trace on --project=chromium --project=firefox",
    "// === SMOKE - ULTIMA-MILLA ===": "",
    "test:um:pedido": "playwright test tests/e2e/modules/ultimamilla/pedido-crear.test.ts --trace on",
    "// === e2e API Legacy option 1  ===": "",
    "test:legacy:entidades": "playwright test tests/e2e/modules/01-entidades/ --trace on --workers=1",
    "// === e2e API legacy option 2 ===": "",
    "test:legacy:setup": "playwright test tests/e2e/suites/base-entities.setup.ts --trace on",
    "test:legacy:contratos": "playwright test tests/e2e/modules/02-operaciones/contratos/ --trace on",
    "test:legacy:viajes": "playwright test tests/e2e/modules/02-operaciones/viajes/ --trace on",
    "test:legacy:monitoreo": "playwright test tests/e2e/modules/02-operaciones/Monitoreo/ --trace on",
    "// === e2e  solo Viajes ===": "",
    "test:legacy:fullviajes": "npx playwright test tests/e2e/modules/02-operaciones/viajes/viajes-planificar.test.ts --project=chromium --workers=1 && npx playwright test tests/e2e/modules/02-operaciones/viajes/viajes-asignar.test.ts --project=chromium --workers=1 && npx playwright test tests/e2e/modules/02-operaciones/Monitoreo/viajes-monitoreo.test.ts --project=chromium --workers=1",
    "test:legacy:fullviajes:firefox": "npx playwright test tests/e2e/modules/02-operaciones/viajes/viajes-planificar.test.ts --project=firefox --workers=1 && npx playwright test tests/e2e/modules/02-operaciones/viajes/viajes-asignar.test.ts --project=firefox --workers=1 && npx playwright test tests/e2e/modules/02-operaciones/Monitoreo/viajes-monitoreo.test.ts --project=firefox --workers=1",
    "test:legacy:fullviajes:all": "npm run test:legacy:fullviajes && npm run test:legacy:fullviajes:firefox",
    "// === SMOKE TMS ENV=DEMO cross-env ===": "",
    "test:demo:transportista": " cross-env ENV=DEMO playwright test tests/e2e/modules/01-entidades/transport/transportistas-crear.test.ts --trace on",
    "test:demo:cliente": "cross-env ENV=DEMO playwright test tests/e2e/modules/01-entidades/clientes/cliente-crear.test.ts --trace on",
    "test:demo:vehiculo": "cross-env ENV=DEMO playwright test tests/e2e/modules/01-entidades/vehiculos/vehiculo-crear.test.ts --trace on",
    "test:demo:conductor": "cross-env ENV=DEMO playwright test tests/e2e/modules/01-entidades/conductor/conductor-crear.test.ts --trace on",
    "test:demo:contrato": "cross-env ENV=DEMO playwright test tests/e2e/modules/02-operaciones/contratos/contrato-crear.test.ts --trace on",
    "// === e2e API legacy ENV=DEMO cross-env ===": "",
    "test:demo:entidades": "cross-env ENV=DEMO playwright test tests/e2e/modules/01-entidades/ --trace on --workers=1",
    "test:demo:contratos": "cross-env ENV=DEMO playwright test tests/e2e/modules/02-operaciones/contratos/contrato-crear.test.ts --trace on",
    "// === FULL FLOWS TMS ENV=QA ===": "",
    "test:trip:full-flow": "npx playwright test tests/e2e/modules/02-operaciones/Monitoreo/viajes-finalizar-e2e.test.ts --trace on",
    "test:full-smoke-flow": "playwright test tests/e2e/modules/01-entidades/ tests/e2e/modules/02-operaciones/contratos/ tests/e2e/modules/02-operaciones/viajes/ tests/e2e/modules/02-operaciones/Monitoreo/ --trace on",
    "// === UTILITIES ===": "",
    "show-report": "playwright show-report",
    "codegen": "playwright codegen https://moveontruckqa.bermanntms.cl"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "playwright": "^1.58.0",
    "playwright-core": "^1.58.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.19.30",
    "cross-env": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}