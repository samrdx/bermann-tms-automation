{
  "name": "qa-automation-framework",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
      "build": "tsc",
      "clean": "rm -rf reports/* logs/*",
      
      "// === E2E TESTS (Producción) ===": "",
      "test:all": "tsx tests/e2e/**/*.test.ts",
      "test:all:suite": "tsx tests/run-all.ts",
      
      "// Auth Tests": "",
      "test:login": "cross-env HEADLESS=false tsx tests/e2e/auth/login.test.ts",
      "test:login:headless": "cross-env HEADLESS=true tsx tests/e2e/auth/login.test.ts",
      "test:logout": "cross-env HEADLESS=false tsx tests/e2e/auth/logout.test.ts",
      "test:login:negative": "cross-env HEADLESS=false tsx tests/e2e/auth/login-negative.test.ts",
      "test:full-flow": "cross-env HEADLESS=false tsx tests/e2e/auth/full-flow.test.ts",
      
      "// Contratos Tests": "",
      "test:contratos:crear": "cross-env HEADLESS=false tsx tests/e2e/contratos/contratos-crear.test.ts",
      "test:contratos:crear:headless": "cross-env HEADLESS=true tsx tests/e2e/contratos/contratos-crear.test.ts",
      
      "// Viajes Tests": "",
      "test:viajes:planificar": "cross-env HEADLESS=false tsx tests/e2e/viajes/viajes-planificar.test.ts",
      "test:viajes:planificar:headless": "cross-env HEADLESS=true tsx tests/e2e/viajes/viajes-planificar.test.ts",
      "test:viajes:asignar": "cross-env HEADLESS=false tsx tests/e2e/viajes/viajes-asignar.test.ts",
      "test:viajes:asignar:headless": "cross-env HEADLESS=true tsx tests/e2e/viajes/viajes-asignar.test.ts",
      
      "// === EXPLORATION (Inspección de páginas) ===": "",
      "test:explore:contratos": "cross-env HEADLESS=false tsx tests/exploration/inspect-contratos.ts",
      "test:explore:viajes": "cross-env HEADLESS=false tsx tests/exploration/inspect-viajes.ts",
      
      
      "// === EXPERIMENTS (Demos/Pruebas) ===": "",
      "test:stagehand:simple": "cross-env HEADLESS=false tsx tests/experiments/stagehand-simple.test.ts",
      "test:stagehand:ai-login": "cross-env HEADLESS=false tsx tests/experiments/stagehand-login-ai.test.ts",
      "test:experiments:login": "cross-env HEADLESS=false tsx tests/experiments/login-experiments.test.ts"
    },
  "dependencies": {
    "@browserbasehq/stagehand": "^3.0.8",
    "@playwright/test": "^1.58.0",
    "dotenv": "^16.6.1",
    "playwright": "^1.58.0",
    "playwright-core": "^1.58.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.30",
    "cross-env": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
