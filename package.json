{
  "name": "qa-automation-framework",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf reports/* logs/*",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "// === COMMON / SMOKE === ": "",
    "test:auth": "playwright test tests/e2e/auth/",
    "test:auth:login": "playwright test tests/e2e/auth/login.test.ts",
    "test:auth:logout": "playwright test tests/e2e/auth/logout.test.ts",
    "// === QA ENVIRONMENT (Default) === ": "",
    "// === Smoke tests === ": "",
    "test:qa:entity:transportista": "cross-env ENV=QA playwright test tests/e2e/modules/01-entidades/transport/transportistas-crear.test.ts --trace on",
    "test:qa:entity:cliente": "cross-env ENV=QA playwright test tests/e2e/modules/01-entidades/clientes/cliente-crear.test.ts --trace on",
    "test:qa:entity:vehiculo": "cross-env ENV=QA playwright test tests/e2e/modules/01-entidades/vehiculos/vehiculo-crear.test.ts --trace on",
    "test:qa:entity:conductor": "cross-env ENV=QA playwright test tests/e2e/modules/01-entidades/conductor/conductor-crear.test.ts --trace on",
    "test:qa:op:contrato": "cross-env ENV=QA playwright test tests/e2e/modules/02-operaciones/contratos/contrato-crear.test.ts --trace on",
    "test:qa:op:contrato2cliente": "cross-env ENV=QA playwright test tests/e2e/modules/02-operaciones/contratos/contrato2cliente-crear.test.ts --trace on",
    "test:qa:legacy:planificar": "cross-env ENV=QA playwright test tests/e2e/modules/02-operaciones/viajes/viajes-planificar.test.ts --workers=1",
    "test:qa:legacy:asignar": "cross-env ENV=QA playwright test tests/e2e/modules/02-operaciones/viajes/viajes-asignar.test.ts --trace on",
    "test:qa:legacy:finalizar": "cross-env ENV=QA playwright test tests/e2e/modules/02-operaciones/Monitoreo/viajes-monitoreo.test.ts --trace on",
    "// === Regression tests === ": "",
    "test:qa:legacy:setup": "cross-env ENV=QA playwright test tests/e2e/suites/base-entities.setup.ts --workers=1",
    "test:qa:legacy:entidades": "cross-env ENV=QA playwright test tests/e2e/modules/01-entidades/ --trace on --workers=1",
    "test:qa:legacy:contratos": "cross-env ENV=QA playwright test tests/e2e/modules/02-operaciones/contratos/ --workers=1",
    "test:qa:legacy:viajes": "npm run test:qa:legacy:planificar && npm run test:qa:legacy:asignar && npm run test:qa:legacy:finalizar",
    "test:qa:full-smoke": "npm run test:qa:legacy:entidades && npm run test:qa:legacy:contratos && npm run test:qa:legacy:viajes",
    "// === e2e tests === ": "",
    "test:qa:trip:full-flow": "cross-env ENV=QA playwright test tests/e2e/suites/viajes-finalizar-e2e.test.ts --trace on",
    "// === DEMO ENVIRONMENT === ": "",
    "test:demo:entity:transportista": "cross-env ENV=DEMO playwright test tests/e2e/modules/01-entidades/transport/transportistas-crear.test.ts --trace on",
    "test:demo:entity:cliente": "cross-env ENV=DEMO playwright test tests/e2e/modules/01-entidades/clientes/cliente-crear.test.ts --trace on",
    "test:demo:entity:vehiculo": "cross-env ENV=DEMO playwright test tests/e2e/modules/01-entidades/vehiculos/vehiculo-crear.test.ts --trace on",
    "test:demo:entity:conductor": "cross-env ENV=DEMO playwright test tests/e2e/modules/01-entidades/conductor/conductor-crear.test.ts --trace on",
    "test:demo:op:contrato": "cross-env ENV=DEMO playwright test tests/e2e/modules/02-operaciones/contratos/contrato-crear.test.ts --trace on",
    "test:demo:op:contrato2cliente": "cross-env ENV=DEMO playwright test tests/e2e/modules/02-operaciones/contratos/contrato2cliente-crear.test.ts --trace on",
    "test:demo:legacy:entidades": "cross-env ENV=DEMO playwright test tests/e2e/modules/01-entidades/ --trace on --workers=1",
    "test:demo:legacy:contratos": "cross-env ENV=DEMO playwright test tests/e2e/modules/02-operaciones/contratos/ --trace on",
    "test:demo:legacy:planificar": "cross-env ENV=DEMO playwright test tests/e2e/modules/02-operaciones/viajes/viajes-planificar.test.ts --project=chromium --workers=1 --trace on",
    "test:demo:legacy:asignar": "cross-env ENV=DEMO playwright test tests/e2e/modules/02-operaciones/viajes/viajes-asignar.test.ts --project=chromium --workers=1 --trace on",
    "test:demo:legacy:finalizar": "cross-env ENV=DEMO playwright test tests/e2e/modules/02-operaciones/Monitoreo/viajes-monitoreo.test.ts --project=chromium --workers=1 --trace on",
    "test:demo:legacy:viajes": "npm run test:demo:legacy:planificar && npm run test:demo:legacy:asignar && npm run test:demo:legacy:finalizar",
    "// === demo e2e tests === ": "",
    "test:demo:trip:full-flow": "cross-env ENV=DEMO playwright test tests/e2e/suites/viajes-finalizar-e2e.test.ts --trace on",
    "// === UTILITIES === ": "",
    "show-report": "playwright show-report",
    "codegen:qa": "playwright codegen https://moveontruckqa.bermanntms.cl",
    "codegen:demo": "playwright codegen https://demo.bermanntms.cl"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "playwright": "^1.58.0",
    "playwright-core": "^1.58.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.19.30",
    "cross-env": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}