{
    "files.exclude": {
        "**/node_modules": true,
        "**/dist": true,
        "**/logs": true,
        "**/reports": true
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/dist": true,
        "**/logs": true
    },
    "files.watcherExclude": {
        "**/node_modules/**": true,
        "**/dist/**": true,
        "**/logs/**": true,
        "**/reports/**": true
    },
    "scm.folders": [
        "${workspaceFolder}"
    ],
    "scm.repositories": [
        {
            "path": "${workspaceFolder}"
        }
    ]
}