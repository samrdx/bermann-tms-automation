{
  "name": "mobile",
  "type": "module",
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@wdio/allure-reporter": "^9.27.0",
    "@wdio/appium-service": "^9.27.0",
    "@wdio/cli": "^9.27.0",
    "@wdio/globals": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "appium": "^3.2.2",
    "appium-uiautomator2-driver": "^7.1.0",
    "expect-webdriverio": "^5.6.5"
  },
  "scripts": {
    "wdio": "wdio run ./wdio.conf.ts",
    "wdio:concise": "MOBILE_WDIO_LOG_LEVEL=warn MOBILE_WDIO_WEBDRIVER_LOG_LEVEL=error MOBILE_LOG_LEVEL=info npm run wdio",
    "wdio:debug": "MOBILE_WDIO_LOG_LEVEL=info MOBILE_WDIO_WEBDRIVER_LOG_LEVEL=info MOBILE_LOG_LEVEL=debug npm run wdio",
    "test:smoke:auth": "npm run wdio -- --spec ./test/specs/auth/login.native.e2e.ts",
    "pre-run:sanitize-device": "npx --yes tsx ./scripts/pre-run-device-sanitize.ts",
    "smoke:metrics": "npx --yes tsx ./scripts/smoke-metrics.ts"
  }
}
